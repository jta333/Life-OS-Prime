# Copy this file to .env and fill in your own values.
# .env is gitignored and must NEVER be committed.
#
# Each person who clones the repo creates their own .env with their own keys.
# Delete the lines you don't need and add your own.

# ---- Generic app config ----
NODE_ENV=development
PORT=3000

# ---- Example: a third-party API key ----
API_KEY=

# ---- Example: database connection ----
DATABASE_URL=

# ---- Example: auth / session secret ----
# Generate a random value, e.g.:  openssl rand -hex 32
SESSION_SECRET=

# ---- Example: Supabase (delete if unused) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Example: OpenAI / Anthropic (delete if unused) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
