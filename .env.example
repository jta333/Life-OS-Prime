# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Access control (Google SSO allowlist) -----
# Comma-separated list of emails allowed to sign in. Leave empty to allow
# anyone (useful for self-hosters). Set it to your own address to lock the
# app down to you alone. Server-only — keep your real email out of the repo.
ALLOWED_EMAILS=

# ----- Anthropic (AI coach + insights) -----
# If omitted, the app runs on deterministic scores only and the coach is disabled.
ANTHROPIC_API_KEY=sk-ant-...

# ----- App -----
# Absolute base URL of the running app. Used server-side by the check-in flow
# to call its own /api/check-in/analyze route for the AI daily summary.
# MUST be set to the deployed origin in production (e.g.
# https://life-os-prime.vercel.app) — otherwise that self-call hits localhost
# and the check-in AI summary silently never generates.
NEXT_PUBLIC_APP_URL=http://localhost:3000
