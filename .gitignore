# ---- Secrets & environment ----
# Never commit real credentials. Use .env locally; commit .env.example instead.
.env
.env.*
!.env.example
*.local

# Keys & certificates
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa*
*.keystore
secrets.*
credentials.*
service-account*.json
gha-creds-*.json

# Cloud / tool credentials
.aws/
.gcloud/
.netrc

